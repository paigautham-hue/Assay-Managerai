# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://assay:assay-dev-password@localhost:5432/assay
POSTGRES_PASSWORD=assay-dev-password

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string

# ── AI API Keys ───────────────────────────────────────────────────────────────
# Google Gemini (required — powers the live interview voice engine)
GOOGLE_API_KEY=your-google-api-key

# Anthropic Claude (required — powers Advocate, Prosecutor, Operator assessors)
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI (required — powers Psychologist assessor)
OPENAI_API_KEY=your-openai-api-key

# ── Optional AI Services ─────────────────────────────────────────────────────
# AssemblyAI (sentiment analysis — falls back to keyword analysis if not set)
ASSEMBLYAI_API_KEY=

# Hume AI (emotion/prosody analysis — skipped if not set)
HUME_API_KEY=

# ── Google OAuth (optional — enables "Sign in with Google") ───────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Voice Provider ────────────────────────────────────────────────────────────
# Which voice engine to use: "gemini" (default) or "openai"
VOICE_PROVIDER=gemini

# ── App Configuration ────────────────────────────────────────────────────────
APP_URL=http://localhost:8080
PORT=8080
NODE_ENV=production
