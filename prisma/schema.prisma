generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  users    User[]
  sessions   InterviewSession[]
  candidates Candidate[]

  @@map("organizations")
}

// Maps to the existing Manus template users table which has:
// id (int autoincrement), openId, name, email, loginMethod, role (enum user/admin),
// createdAt, updatedAt, lastSignedIn + ASSAY columns we added:
// status, password_hash, google_id, organization_id, last_active_at, created_at, updated_at
model User {
  id             Int       @id @default(autoincrement())
  email          String?   @unique @db.VarChar(320)
  name           String?   @db.Text
  role           String    @default("viewer")
  status         String    @default("active")
  passwordHash   String?   @map("password_hash") @db.Text
  googleId       String?   @unique @map("google_id")
  organizationId String?   @map("organization_id")
  lastActiveAt   DateTime? @map("last_active_at")
  // Use the camelCase columns that already exist in the table
  createdAt      DateTime  @default(now()) @map("createdAt")
  updatedAt      DateTime  @updatedAt @map("updatedAt")

  organization  Organization? @relation(fields: [organizationId], references: [id])
  invitations   Invitation[]  @relation("InvitedBy")
  activityLogs  ActivityLog[]

  @@map("users")
}

model Invitation {
  id          String    @id @default(uuid())
  email       String
  role        String    @default("interviewer")
  token       String    @unique
  invitedById Int       @map("invited_by")
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  invitedBy User @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    Int?     @map("user_id")
  actorId   Int?     @map("actor_id")
  action    String
  details   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}

model InterviewSession {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id")
  candidateId    String?   @map("candidate_id")
  setup          Json
  status         String    @default("preparing")
  startedAt      DateTime? @map("started_at")
  endedAt        DateTime? @map("ended_at")
  voiceProvider  String    @default("gemini") @map("voice_provider")
  videoEnabled   Boolean   @default(false) @map("video_enabled")
  audioData      Bytes?    @map("audio_data") @db.MediumBlob
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization?    @relation(fields: [organizationId], references: [id])
  candidate    Candidate?       @relation(fields: [candidateId], references: [id])
  transcripts  TranscriptEntry[]
  observations Observation[]
  verdicts     AssessorVerdict[]
  reports      Report[]

  @@map("interview_sessions")
}

model TranscriptEntry {
  id             String   @id @default(uuid())
  sessionId      String   @map("session_id")
  speaker        String
  text           String   @db.Text
  timestamp      DateTime
  audioTimestamp Float?   @map("audio_timestamp")

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("transcript_entries")
}

model Observation {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  type        String
  dimension   String?
  gate        String?
  description String   @db.Text
  evidence    String   @db.Text
  confidence  Float
  timestamp   DateTime

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("observations")
}

model AssessorVerdict {
  id                     String  @id @default(uuid())
  sessionId              String  @map("session_id")
  role                   String
  recommendation         String
  confidence             Float
  narrative              String  @db.Text
  dimensionScores        Json    @map("dimension_scores")
  deepSignalScores       Json?   @map("deep_signal_scores")
  psychologicalScreening Json?   @map("psychological_screening")
  gateEvaluations        Json    @map("gate_evaluations")
  keyInsights            Json    @map("key_insights")
  dissent                String? @db.Text

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("assessor_verdicts")
}

model Report {
  id            String   @id @default(uuid())
  sessionId     String   @map("session_id")
  candidateName String   @map("candidate_name")
  roleName      String   @map("role_name")
  reportData    Json     @map("report_data")
  coachingReport Json?   @map("coaching_report")
  createdAt     DateTime @default(now()) @map("created_at")

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model InterviewInvite {
  id             String    @id @default(uuid())
  token          String    @unique
  candidateName  String    @map("candidate_name")
  candidateEmail String?   @map("candidate_email")
  roleName       String    @map("role_name")
  roleLevel      String    @map("role_level")
  jobDescription String?   @map("job_description") @db.Text
  activeGates    Json      @map("active_gates")
  interviewMode  String    @default("active") @map("interview_mode")
  status         String    @default("pending")
  sessionId      String?   @map("session_id")
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("interview_invites")
}

model CalibrationSession {
  id        String   @id @default(uuid())
  reportId  String   @map("report_id")
  title     String
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")

  notes CalibrationNote[]

  @@map("calibration_sessions")
}

model CalibrationNote {
  id                   String   @id @default(uuid())
  calibrationSessionId String   @map("calibration_session_id")
  userId               Int      @map("user_id")
  userName             String   @map("user_name")
  content              String   @db.Text
  sectionRef           String?  @map("section_ref")
  createdAt            DateTime @default(now()) @map("created_at")

  session CalibrationSession @relation(fields: [calibrationSessionId], references: [id], onDelete: Cascade)

  @@map("calibration_notes")
}

model ReportFeedback {
  id                String   @id @default(uuid())
  reportId          String   @map("report_id")
  userId            Int      @map("user_id")
  overallAccuracy   Int
  hireOutcome       String?  @map("hire_outcome")
  performanceNote   String?  @map("performance_note") @db.Text
  dimensionFeedback Json?    @map("dimension_feedback")
  gateFeedback      Json?    @map("gate_feedback")
  comments          String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([reportId, userId])
  @@map("report_feedback")
}

model Candidate {
  id               String    @id @default(uuid())
  organizationId   String?   @map("organization_id")
  name             String
  email            String?
  phone            String?
  linkedinUrl      String?   @map("linkedin_url")
  githubUrl        String?   @map("github_url")
  portfolioUrl     String?   @map("portfolio_url")
  source           String?
  sourceDetail     String?   @map("source_detail")
  currentRole      String?   @map("current_role")
  currentCompany   String?   @map("current_company")
  yearsExperience  Int?      @map("years_experience")
  salaryExpectation String?  @map("salary_expectation")
  noticePeriod     String?   @map("notice_period")
  pipelineStage    String    @default("applied") @map("pipeline_stage")
  rejectionReason  String?   @map("rejection_reason")
  tags             Json      @default("[]")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization  Organization?          @relation(fields: [organizationId], references: [id])
  sessions      InterviewSession[]
  intelligence  CandidateIntelligence[]
  notes         CandidateNote[]
  references    CandidateReference[]
  documents     CandidateDocument[]

  @@map("candidates")
}

model CandidateDocument {
  id          String   @id @default(uuid())
  candidateId String   @map("candidate_id")
  type        String
  filename    String
  mimeType    String   @map("mime_type")
  content     String   @db.Text
  rawData     Bytes?   @map("raw_data") @db.MediumBlob
  createdAt   DateTime @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_documents")
}

model CandidateIntelligence {
  id          String   @id @default(uuid())
  candidateId String   @map("candidate_id")
  type        String
  data        Json
  sourceText  String?  @map("source_text") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_intelligence")
}

model CandidateNote {
  id          String   @id @default(uuid())
  candidateId String   @map("candidate_id")
  userId      String   @map("user_id")
  userName    String   @map("user_name")
  content     String   @db.Text
  type        String   @default("general")
  createdAt   DateTime @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_notes")
}

model CandidateReference {
  id              String    @id @default(uuid())
  candidateId     String    @map("candidate_id")
  refereeName     String    @map("referee_name")
  refereeEmail    String?   @map("referee_email")
  refereePhone    String?   @map("referee_phone")
  refereeRelation String    @map("referee_relation")
  refereeCompany  String?   @map("referee_company")
  status          String    @default("pending")
  token           String?   @unique
  responses       Json?
  aiAnalysis      Json?     @map("ai_analysis")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_references")
}

model SystemPromptVersion {
  id          String   @id @default(uuid())
  role        String
  version     Int
  prompt      String   @db.Text
  isActive    Boolean  @default(false) @map("is_active")
  performance Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([role, version])
  @@map("system_prompt_versions")
}
